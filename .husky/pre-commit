#!/bin/sh

echo "Running pre-commit checks..."

# Type check
echo "→ Checking TypeScript types..."
npx tsc --noEmit 2>/dev/null
if [ $? -ne 0 ]; then
  echo "✗ TypeScript type errors found. Fix them before committing."
  exit 1
fi

# Lint
echo "→ Running ESLint..."
npx eslint . --ext .ts,.tsx --max-warnings 0 2>/dev/null
if [ $? -ne 0 ]; then
  echo "✗ Linting errors found. Fix them before committing."
  exit 1
fi

# Format check
echo "→ Checking formatting with Prettier..."
npx prettier --check "**/*.{ts,tsx,js,jsx,json,css,md}" 2>/dev/null
if [ $? -ne 0 ]; then
  echo "✗ Formatting issues found. Run 'npx prettier --write .' to fix."
  exit 1
fi

echo "✓ All checks passed."
